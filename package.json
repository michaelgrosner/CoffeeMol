{
  "name": "coffeemol",
  "version": "1.0.0",
  "description": "An embeddable molecular visualizer for HTML5 browsers, written in TypeScript. Renders PDB and mmCIF files on a `<canvas>` element using 2D drawing APIs — no WebGL required, no runtime dependencies.",
  "main": "CoffeeMol.js",
  "types": "CoffeeMol.d.ts",
  "scripts": {
    "type-check": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "build": "npm run type-check && esbuild src/coffeemol.ts --bundle --outfile=CoffeeMol.js --format=iife --minify --sourcemap && tsc --declaration --emitDeclarationOnly --outFile CoffeeMol.d.ts",
    "dev": "esbuild src/coffeemol.ts --bundle --outfile=CoffeeMol.js --format=iife --sourcemap --watch --servedir=. --serve-fallback=index.html",
    "test": "npm run type-check && vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/michaelgrosner/CoffeeMol.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/michaelgrosner/CoffeeMol/issues"
  },
  "homepage": "https://github.com/michaelgrosner/CoffeeMol#readme",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/three": "^0.184.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "three": "^0.184.0"
  }
}
