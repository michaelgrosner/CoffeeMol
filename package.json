{
  "name": "coffeemol",
  "version": "1.0.0",
  "description": "An embeddable molecular visualizer for HTML5 browsers, written in vanilla JavaScript. Renders PDB files on a `<canvas>` element using 2D drawing APIs — no WebGL required, no build step, no dependencies.",
  "main": "CoffeeMol.js",
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "npm run type-check && esbuild src/coffeemol.ts --bundle --outfile=CoffeeMol.js --format=iife",
    "dev": "esbuild src/coffeemol.ts --bundle --outfile=CoffeeMol.js --format=iife --watch --servedir=.",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/michaelgrosner/CoffeeMol.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/michaelgrosner/CoffeeMol/issues"
  },
  "homepage": "https://github.com/michaelgrosner/CoffeeMol#readme",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
