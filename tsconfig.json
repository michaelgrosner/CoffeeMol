{
    "compilerOptions": {
        "target": "ES2020",
        "lib": ["ES2020", "DOM"],
        "module": "None",
        "outFile": "CoffeeMol.js",
        "ignoreDeprecations": "6.0",
        "strict": true,
        "noImplicitAny": true,
        "strictNullChecks": true,
        "useUnknownInCatchVariables": false
    },
    "include": ["CoffeeMol.ts"]
}
